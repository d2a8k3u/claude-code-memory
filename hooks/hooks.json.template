{
  "description": "Claude Memory - automatic context loading, error recall, and memory persistence",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{PLUGIN_DIR}}/server/dist/cli.js session-start",
            "statusMessage": "Loading project memory...",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": { "tool_name": "Bash" },
        "hooks": [
          {
            "type": "command",
            "command": "node {{PLUGIN_DIR}}/server/dist/cli.js error-context",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node {{PLUGIN_DIR}}/server/dist/cli.js session-end",
            "statusMessage": "Saving session memory...",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
